fun fib(n) {
  if (n <= 1) return n;
  return fib(n - 2) + fib(n - 1);
}

var start = clock();
for (var i = 0; i < 32; i = i + 1) {
  print fib(i);
}

print "Time taken in seconds:";
print clock() - start;

